# WASM Makefile for Digital Twin generation
# Requires Emscripten (emcc) and Verilator

VERILATOR = verilator
EMCC = emcc

# Project source directory
SRC_DIR = ../src
OBJ_DIR = obj_dir

# Verilog source files
SOURCES = $(SRC_DIR)/project.v \
          $(SRC_DIR)/fp8_mul.v \
          $(SRC_DIR)/fp8_mul_lns.v \
          $(SRC_DIR)/fp8_mul_serial_lns.v \
          $(SRC_DIR)/fp8_aligner.v \
          $(SRC_DIR)/accumulator.v

VARIANT ?= Full

# Set parameters based on variant
ifeq ($(VARIANT),Full)
    PARAMS = -GALIGNER_WIDTH=40 -GACCUMULATOR_WIDTH=32 -GSUPPORT_E4M3=1 -GSUPPORT_E5M2=1 -GSUPPORT_MXFP6=1 -GSUPPORT_MXFP4=1 -GSUPPORT_INT8=1 -GSUPPORT_PIPELINING=1 -GSUPPORT_ADV_ROUNDING=1 -GSUPPORT_MIXED_PRECISION=1 -GSUPPORT_VECTOR_PACKING=1 -GENABLE_SHARED_SCALING=1 -GSUPPORT_MX_PLUS=1 -GSUPPORT_INPUT_BUFFERING=1 -GSUPPORT_SERIAL=0
else ifeq ($(VARIANT),Lite)
    PARAMS = -GALIGNER_WIDTH=40 -GACCUMULATOR_WIDTH=32 -GSUPPORT_E4M3=1 -GSUPPORT_E5M2=1 -GSUPPORT_MXFP6=0 -GSUPPORT_MXFP4=1 -GSUPPORT_INT8=1 -GSUPPORT_PIPELINING=1 -GSUPPORT_ADV_ROUNDING=0 -GSUPPORT_MIXED_PRECISION=1 -GSUPPORT_VECTOR_PACKING=0 -GENABLE_SHARED_SCALING=1 -GSUPPORT_MX_PLUS=0 -GSUPPORT_INPUT_BUFFERING=0 -GSUPPORT_SERIAL=0
else ifeq ($(VARIANT),Tiny)
    PARAMS = -GALIGNER_WIDTH=40 -GACCUMULATOR_WIDTH=32 -GSUPPORT_E4M3=1 -GSUPPORT_E5M2=0 -GSUPPORT_MXFP6=0 -GSUPPORT_MXFP4=0 -GSUPPORT_INT8=0 -GSUPPORT_PIPELINING=0 -GSUPPORT_ADV_ROUNDING=0 -GSUPPORT_MIXED_PRECISION=0 -GSUPPORT_VECTOR_PACKING=0 -GENABLE_SHARED_SCALING=0 -GSUPPORT_MX_PLUS=0 -GSUPPORT_INPUT_BUFFERING=0 -GSUPPORT_SERIAL=0
else ifeq ($(VARIANT),Ultra-Tiny)
    PARAMS = -GALIGNER_WIDTH=32 -GACCUMULATOR_WIDTH=24 -GSUPPORT_E4M3=1 -GSUPPORT_E5M2=0 -GSUPPORT_MXFP6=0 -GSUPPORT_MXFP4=0 -GSUPPORT_INT8=0 -GSUPPORT_PIPELINING=0 -GSUPPORT_ADV_ROUNDING=0 -GSUPPORT_MIXED_PRECISION=0 -GSUPPORT_VECTOR_PACKING=0 -GENABLE_SHARED_SCALING=0 -GSUPPORT_MX_PLUS=0 -GSUPPORT_INPUT_BUFFERING=0 -GSUPPORT_SERIAL=0
else ifeq ($(VARIANT),Tiny-Serial)
    PARAMS = -GALIGNER_WIDTH=32 -GACCUMULATOR_WIDTH=24 -GSUPPORT_E4M3=0 -GSUPPORT_E5M2=0 -GSUPPORT_MXFP6=0 -GSUPPORT_MXFP4=1 -GSUPPORT_INT8=0 -GSUPPORT_PIPELINING=0 -GSUPPORT_ADV_ROUNDING=0 -GSUPPORT_MIXED_PRECISION=0 -GSUPPORT_VECTOR_PACKING=0 -GENABLE_SHARED_SCALING=0 -GSUPPORT_MX_PLUS=0 -GSUPPORT_INPUT_BUFFERING=0 -GSUPPORT_SERIAL=1
endif

# Verilator root detection
VERILATOR_ROOT = $(shell $(VERILATOR) -V | grep VERILATOR_ROOT | head -1 | awk '{print $$3}')

# Emscripten flags
EMCC_FLAGS = -O3 -s WASM=1 -s ALLOW_MEMORY_GROWTH=1 \
             --bind \
             -DVL_IGNORE_UNKNOWN_ARCH \
             -I$(OBJ_DIR) \
             -I$(VERILATOR_ROOT)/include \
             -I$(VERILATOR_ROOT)/include/vltstd

# Verilator runtime sources
VERILATOR_SOURCES = $(VERILATOR_ROOT)/include/verilated.cpp \
                    $(VERILATOR_ROOT)/include/verilated_threads.cpp

all: digital_twin_$(VARIANT).js

verilate: $(SOURCES)
	$(VERILATOR) --cc $(SOURCES) \
		--top-module tt_um_chatelao_fp8_multiplier \
		-I$(SRC_DIR) \
		$(PARAMS) \
		-Wno-WIDTHTRUNC -Wno-WIDTHEXPAND \
		--Mdir $(OBJ_DIR)

digital_twin_$(VARIANT).js: verilate digital_twin.cpp
	$(EMCC) $(EMCC_FLAGS) digital_twin.cpp $(shell ls $(OBJ_DIR)/*.cpp | grep -v "__ALL.cpp") $(VERILATOR_SOURCES) -o digital_twin_$(VARIANT).js

clean:
	rm -rf $(OBJ_DIR) *.js *.wasm
