IO_PORT "uo_out[2]" PULL_MODE=UP IO_TYPE=LVCMOS33;
IO_LOC "uo_out[3]" 44;
IO_PORT "uo_out[3]" PULL_MODE=UP IO_TYPE=LVCMOS33;
IO_LOC "uo_out[4]" 22;
IO_PORT "uo_out[4]" PULL_MODE=UP IO_TYPE=LVCMOS33;
IO_LOC "uo_out[5]" 7;
IO_PORT "uo_out[5]" PULL_MODE=UP IO_TYPE=LVCMOS33;
IO_LOC "uo_out[6]" 8;
IO_PORT "uo_out[6]" PULL_MODE=UP IO_TYPE=LVCMOS33;
