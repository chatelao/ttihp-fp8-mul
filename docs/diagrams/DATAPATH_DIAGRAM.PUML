@startuml DATAPATH_DIAGRAM
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

' Green Theme Overrides
skinparam backgroundColor white
skinparam component {
    BackgroundColor #90EE90
    BorderColor #006400
    FontColor #000000
}
skinparam rectangle<<container>> {
    BackgroundColor #90EE90
    BorderColor #006400
    FontColor #000000
}
skinparam rectangle<<boundary>> {
    FontSize 20
    BorderColor #006400
    FontColor #000000
}
skinparam rectangle<<container_boundary>> {
    FontSize 20
    BorderColor #006400
    FontColor #000000
}
skinparam rectangle<<system_boundary>> {
    FontSize 20
    BorderColor #006400
    FontColor #000000
}
skinparam Arrow {
    Color black
    FontColor black
}
skinparam legend {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}

UpdateBoundaryStyle("container", $type="container")

title OCP MXFP8 MAC Unit - Internal Datapath (Registers & Processing)

Container_Boundary(input_pins, "Physical Interface") {
    Component(ui_in, "ui_in[7:0]", "Input Pins", "Metadata, Scale A, Operand A (8 bits)")
    Component(uio_in, "uio_in[7:0]", "Input Pins", "Metadata, Scale B, Operand B (8 bits)")
}

Container_Boundary(reg_file, "Configuration & Control (57 FFs)") {
    Component(cfg_reg0, "Cycle 0 Regs", "25 FFs", "Metadata (19) + Cycle Counter (6)")
    Component(cfg_reg1, "Cycle 1 Regs", "16 FFs", "Scale A (8), Format A (3), BM Index A (5)")
    Component(cfg_reg2, "Cycle 2 Regs", "16 FFs", "Scale B (8), Format B (3), BM Index B (5)")
}

Container_Boundary(datapath, "Processing Datapath (356 FFs)") {
    Component(fifo, "Input Buffers", "268 FFs", "16x8-bit FIFOs (256) + Ptrs (4) + Packed Bufs (8)")
    Component(mul, "Dual Multipliers", "Logic (0 FFs)", "8x8 / 4x4 / LNS")
    Component(pipe_reg, "Pipeline Regs", "56 FFs", "2x28-bit Product Staging (Prod, Exp, Sign, Exc)")
    Component(align, "Dual Aligners", "Logic (0 FFs)", "40-bit internal Barrel Shifters")
    Component(acc, "32-bit Accumulator", "32 FFs", "32-bit Signed Fixed-point Sum")
}

Container_Boundary(output_logic, "Output Logic (3 FFs)") {
    Component(sticky, "Sticky Regs", "3 FFs", "Exception Flags (NaN, Inf+, Inf-)")
    Component(ser, "Serializer", "Logic (0 FFs)", "Byte Selector")
}

Component(uo_out, "uo_out[7:0]", "Output Pins", "Serialized IEEE 754 Float32 / Debug Probes (8 bits)")

' Dataflow Arrows
Rel_D(ui_in, cfg_reg0, "8 bits / 0 FFs", "Cycle 0")
Rel_D(uio_in, cfg_reg0, "8 bits / 0 FFs", "Cycle 0")
Rel_D(ui_in, cfg_reg1, "8 bits / 0 FFs", "Cycle 1")
Rel_D(uio_in, cfg_reg1, "8 bits / 0 FFs", "Cycle 1")
Rel_D(ui_in, cfg_reg2, "8 bits / 0 FFs", "Cycle 2")
Rel_D(uio_in, cfg_reg2, "8 bits / 0 FFs", "Cycle 2")

Rel_D(ui_in, fifo, "8 bits / 0 FFs", "Stream")
Rel_D(uio_in, fifo, "8 bits / 0 FFs", "Stream")

Rel_D(fifo, mul, "16 bits / 0 FFs", "Operands")
Rel_D(cfg_reg1, mul, "3 bits / 0 FFs", "Format A")
Rel_D(cfg_reg2, mul, "3 bits / 0 FFs", "Format B")

Rel_D(mul, pipe_reg, "56 bits / 56 FFs", "Raw Products")
Rel_D(pipe_reg, align, "56 bits / 0 FFs", "Staged Data")
Rel_L(cfg_reg1, align, "8 bits / 0 FFs", "Scale A")
Rel_L(cfg_reg2, align, "8 bits / 0 FFs", "Scale B")

Rel_D(align, acc, "32 bits / 0 FFs", "Aligned")
Rel_U(acc, acc, "32 bits / 0 FFs", "Feedback")

Rel_D(mul, sticky, "3 bits / 3 FFs", "Exceptions")
Rel_D(acc, ser, "32 bits / 0 FFs", "Result")
Rel_D(sticky, ser, "3 bits / 0 FFs", "Override")

Rel_D(ser, uo_out, "8 bits / 0 FFs", "Output")

@enduml
